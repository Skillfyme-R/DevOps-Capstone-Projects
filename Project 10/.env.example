# ============================================================
# DeployPilot — .env.example
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_NAME=DeployPilot
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-in-production-use-256-bit-random-secret-key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+asyncpg://deploypilot:deploypilot@localhost:5432/deploypilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# GitHub Integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_PREFIX=deploypilot

# Terraform
TERRAFORM_BINARY_PATH=/usr/local/bin/terraform
TERRAFORM_WORKING_DIR=/tmp/deploypilot/runs
TERRAFORM_STATE_BUCKET=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@deploypilot.io

# Slack
SLACK_DEFAULT_WEBHOOK=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging & Monitoring
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# S3
S3_BUCKET_ARTIFACTS=
S3_BUCKET_LOGS=

# Seed / Bootstrap
INITIAL_ADMIN_EMAIL=admin@deploypilot.io
INITIAL_ADMIN_PASSWORD=ChangeMe123!
