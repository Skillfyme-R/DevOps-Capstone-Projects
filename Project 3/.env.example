# ============================================================
# MediCore Platform — Environment Configuration Template
# Copy this file to .env and fill in your local values.
# NEVER commit .env to version control.
# ============================================================

# ── Platform ────────────────────────────────────────────────
MEDICORE_ENVIRONMENT=development
MEDICORE_LOG_LEVEL=info
MEDICORE_LOG_FORMAT=pretty

# ── API Gateway ─────────────────────────────────────────────
GATEWAY_PORT=8090
GATEWAY_HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3005

# ── Auth Service ─────────────────────────────────────────────
AUTH_SERVICE_PORT=9001
MEDICORE_JWT_SECRET=change-this-to-a-64-char-random-string-in-production
MEDICORE_JWT_EXPIRY=15m
MEDICORE_REFRESH_TOKEN_EXPIRY=30d
MEDICORE_SESSION_SECRET=change-this-session-secret-in-production
MEDICORE_BCRYPT_ROUNDS=12

# ── Patient Service ──────────────────────────────────────────
PATIENT_SERVICE_PORT=9002

# ── Appointment Service ──────────────────────────────────────
APPOINTMENT_SERVICE_PORT=9003

# ── Clinical Service ─────────────────────────────────────────
CLINICAL_SERVICE_PORT=9004

# ── Analytics Service ────────────────────────────────────────
ANALYTICS_SERVICE_PORT=9005

# ── Notification Service ─────────────────────────────────────
NOTIFICATION_SERVICE_PORT=9006
SENDGRID_API_KEY=your-sendgrid-api-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── Primary Database (PostgreSQL) ───────────────────────────
MEDICORE_DB_HOST=localhost
MEDICORE_DB_PORT=5434
MEDICORE_DB_USER=medicore
MEDICORE_DB_PASSWORD=medicore_dev_password
MEDICORE_DB_NAME=medicore_dev
MEDICORE_DB_SSL=false
MEDICORE_DB_POOL_MIN=2
MEDICORE_DB_POOL_MAX=20

# ── Cache / Queue (Redis) ────────────────────────────────────
MEDICORE_REDIS_URL=redis://:medicore_redis_pass@localhost:6382
MEDICORE_REDIS_TTL_DEFAULT=300

# ── Object Storage (S3-compatible) ──────────────────────────
MEDICORE_S3_ENDPOINT=http://localhost:9000
MEDICORE_S3_BUCKET_DOCUMENTS=medicore-documents
MEDICORE_S3_BUCKET_IMAGES=medicore-images
MEDICORE_S3_ACCESS_KEY=minioadmin
MEDICORE_S3_SECRET_KEY=minioadmin

# ── HashiCorp Vault (Secrets Management) ────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=medicore-dev-root-token
VAULT_PATH=secret/medicore

# ── Observability ────────────────────────────────────────────
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
LOKI_ENDPOINT=http://localhost:3100
SENTRY_DSN=

# ── FHIR Compliance ─────────────────────────────────────────
FHIR_VERSION=R4
FHIR_BASE_URL=http://localhost:8090/fhir/r4

# ── Frontend ─────────────────────────────────────────────────
REACT_APP_API_BASE_URL=http://localhost:8090/api/v1
REACT_APP_FHIR_BASE_URL=http://localhost:8090/fhir/r4
REACT_APP_ENVIRONMENT=development
REACT_APP_SENTRY_DSN=
PORT=3005
