{
  "name": "medicore-appointments",
  "version": "1.0.0",
  "description": "MediCore Appointment Scheduling & Calendar Service",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only ./src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests --ci",
    "db:migrate": "knex migrate:latest --knexfile src/config/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile src/config/knexfile.js",
    "db:seed": "knex seed:run --knexfile src/config/knexfile.js"
  },
  "dependencies": {
    "bull": "^4.11.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.10.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "prom-client": "^14.2.0",
    "rate-limiter-flexible": "^3.0.6",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "yaml": "^2.3.2"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.7.3",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/morgan": "^1.9.6",
    "@types/node": "^18.17.19",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
