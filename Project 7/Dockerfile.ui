# ─── Stage 1: Build React app ─────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app/ui

COPY ui/package.json ./

# Fix ajv peer dependency conflict known with react-scripts v5 + Node 20
RUN npm install --legacy-peer-deps --silent && \
    npm install ajv@^8.0.0 --legacy-peer-deps --silent

COPY ui/ .

ENV GENERATE_SOURCEMAP=false
ENV CI=false

RUN npm run build

# ─── Stage 2: Serve with Nginx ────────────────────────────────────────────────
FROM nginx:1.27-alpine

LABEL org.opencontainers.image.title="VaultFlow UI"
LABEL org.opencontainers.image.description="VaultFlow Financial Dashboard"

COPY --from=builder /app/ui/build /usr/share/nginx/html
COPY deploy/nginx/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
