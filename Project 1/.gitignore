# =============================================================================
# NexusFinance .gitignore
# =============================================================================

# --- CRITICAL: Secrets (never commit these) ----------------------------------
.env
.env.local
.env.*.local
app-config.local.yaml
*.pem           # TLS certificates
*.key           # Private keys
*.p12           # PKCS12 bundles
*-secret.yaml   # Kubernetes secrets

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# --- Build Outputs ---
dist/
build/
.next/
out/
*.tsbuildinfo
coverage/
.nyc_output/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Infrastructure State (can contain secrets) ---
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl
terraform.tfvars    # Contains real variable values

# --- OS Files ---
.DS_Store
Thumbs.db
*.suo
.idea/
.vscode/settings.json

# --- Financial Data (regulatory requirement: don't store in git) ---
exports/
financial-exports/
audit-dumps/
*.csv.export
