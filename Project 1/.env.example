# =============================================================================
# NexusFinance Platform — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in real values in .env
# 3. NEVER commit .env to git (it's in .gitignore)
# =============================================================================

# ---- Platform ---------------------------------------------------------------
NEXUS_ENVIRONMENT=development
NEXUS_SESSION_SECRET=replace-with-64-char-random-string-use-openssl-rand
NEXUS_BACKEND_SECRET=replace-with-another-64-char-random-string

# ---- PostgreSQL Database ----------------------------------------------------
NEXUS_DB_HOST=localhost
NEXUS_DB_PORT=5432
NEXUS_DB_USER=nexus_user
NEXUS_DB_PASSWORD=nexus_dev_password
NEXUS_DB_NAME=nexusfinance_dev

# ---- Redis Cache ------------------------------------------------------------
NEXUS_REDIS_URL=redis://localhost:6379

# ---- AWS Cloud --------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
