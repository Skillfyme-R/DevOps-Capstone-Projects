pipeline {
  agent any

  environment {
    AWS_REGION   = 'us-east-1'
    AWS_ACCOUNT  = credentials('medicart-aws-account-id')
    ECR_REPO     = "${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/medicart-api"
    EKS_CLUSTER  = 'medicart-dev-cluster'
    HELM_RELEASE = 'medicart'
    HELM_NS      = 'medicart'
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Install Dependencies') {
      steps {
        sh 'pip install -r docker/requirements.txt'
      }
    }

    stage('Unit Tests') {
      steps {
        sh '''
          pytest docker/src/tests/ scripts/tests/ \
            --cov=docker/src \
            --cov-report=xml:coverage.xml \
            --cov-report=term-missing \
            -v
        '''
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: '**/test-results/*.xml'
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        withSonarQubeEnv('sonar') {
          sh '''
            sonar-scanner \
              -Dsonar.projectKey=medicart-platform \
              -Dsonar.projectName="MediCart Healthcare Platform" \
              -Dsonar.python.coverage.reportPaths=coverage.xml
          '''
        }
      }
    }

    stage('Quality Gate') {
      steps {
        timeout(time: 5, unit: 'MINUTES') {
          waitForQualityGate abortPipeline: true
        }
      }
    }

    stage('Terraform Validate') {
      steps {
        withAWS(region: "${AWS_REGION}", credentials: 'medicart-aws-credentials') {
          sh '''
            cd terraform
            terraform fmt -check -recursive
            terraform init -backend=false
            terraform validate
          '''
        }
      }
    }

    stage('Build & Push to ECR') {
      steps {
        withAWS(region: "${AWS_REGION}", credentials: 'medicart-aws-credentials') {
          sh '''
            aws ecr get-login-password --region $AWS_REGION | \
              docker login --username AWS --password-stdin $ECR_REPO

            docker build \
              --build-arg APP_VERSION=$BUILD_NUMBER \
              -t $ECR_REPO:$BUILD_NUMBER \
              -t $ECR_REPO:latest \
              docker/

            docker push $ECR_REPO:$BUILD_NUMBER
            docker push $ECR_REPO:latest
          '''
        }
      }
    }

    stage('Deploy to EKS') {
      steps {
        withAWS(region: "${AWS_REGION}", credentials: 'medicart-aws-credentials') {
          sh '''
            aws eks update-kubeconfig --name $EKS_CLUSTER --region $AWS_REGION

            helm upgrade --install $HELM_RELEASE helm/medicart \
              --namespace $HELM_NS \
              --create-namespace \
              --values helm/medicart/values-dev.yaml \
              --set image.repository=$ECR_REPO \
              --set image.tag=$BUILD_NUMBER \
              --wait \
              --timeout 5m

            kubectl rollout status deployment/medicart-api \
              -n $HELM_NS --timeout=120s
          '''
        }
      }
    }

    stage('Smoke Test') {
      steps {
        sh '''
          POD=$(kubectl get pod -n $HELM_NS -l app.kubernetes.io/name=medicart -o jsonpath='{.items[0].metadata.name}')
          kubectl exec -n $HELM_NS "$POD" -- \
            python -c "import urllib.request; r=urllib.request.urlopen('http://localhost:8080/health'); assert r.status==200"
          echo "MediCart smoke test passed: $ECR_REPO:$BUILD_NUMBER"
        '''
      }
    }
  }

  post {
    success {
      echo "MediCart deployment successful: $ECR_REPO:$BUILD_NUMBER"
    }
    failure {
      echo "MediCart pipeline failed at stage: ${env.STAGE_NAME}"
    }
    always {
      cleanWs()
    }
  }
}
