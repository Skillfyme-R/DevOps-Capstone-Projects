# =============================================================================
# VendorVault — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---- Platform ---------------------------------------------------------------
VV_ENVIRONMENT=development

# ---- PostgreSQL -------------------------------------------------------------
VV_DB_HOST=localhost
VV_DB_PORT=5433
VV_DB_USER=vv_user
VV_DB_PASSWORD=vv_dev_password
VV_DB_NAME=vendorvault_dev

# ---- Redis ------------------------------------------------------------------
VV_REDIS_URL=redis://:vv_redis_dev_password@localhost:6381

# ---- JWT / Session Secrets --------------------------------------------------
VV_BACKEND_SECRET=change-me-to-64-random-chars-in-production-never-commit-this-secret
VV_SESSION_SECRET=change-me-to-64-random-chars-in-production-never-commit-this-secret

# ---- OAuth Providers --------------------------------------------------------
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ---- Stripe (Marketplace Payments + Connect) --------------------------------
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- PayPal -----------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# ---- Razorpay ---------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Email / SMS ------------------------------------------------------------
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Search -----------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# ---- Media / Image Storage --------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Monitoring -------------------------------------------------------------
DATADOG_API_KEY=
DATADOG_APP_KEY=
SENTRY_DSN=

# ---- AWS --------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=info
SQL_DEBUG=false
