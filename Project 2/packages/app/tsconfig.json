{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "build",
    "rootDir": "src",
    "paths": { "*": ["src/*"] },
    "allowJs": true,
    "noEmit": true
  },
  "include": ["src"]
}
