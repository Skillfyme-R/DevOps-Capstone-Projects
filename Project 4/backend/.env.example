# ShieldGrid API — Environment Configuration
# Copy to .env and fill in real values before starting

# ─── Application ───────────────────────────────────────────────────────────
APP_NAME="ShieldGrid API"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ─── Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shieldgrid:shieldgrid@localhost:5432/shieldgrid
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── AWS ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_REPORTS_BUCKET=shieldgrid-reports-dev
S3_ASSETS_BUCKET=shieldgrid-assets-dev

# ─── Scanning ──────────────────────────────────────────────────────────────
SCAN_CONCURRENCY_LIMIT=5
SCAN_TIMEOUT_SECONDS=300
DEPENDENCY_CHECK_ENABLED=true
SAST_ENABLED=true
DAST_ENABLED=true
CONTAINER_SCAN_ENABLED=true
SECRET_DETECTION_ENABLED=true
IAC_SCAN_ENABLED=true

# ─── Notifications ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@shieldgrid.io
SLACK_WEBHOOK_URL=

# ─── Observability ─────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_ENDPOINT=
SENTRY_DSN=
