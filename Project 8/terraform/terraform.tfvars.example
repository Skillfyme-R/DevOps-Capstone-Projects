# CartFlow Terraform variable overrides
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored — never commit real account IDs or secrets.

region             = "us-east-1"
cluster_name       = "cartflow-prod"
cluster_version    = "1.31"
node_instance_type = "t3.small"
node_count         = 2
aws_account_id     = "123456789012"   # replace with your AWS account ID
platform_admin_user = "cartflow-ci"  # IAM user that can assume eks-admin-role
environment        = "production"
platform_name      = "cartflow"
