    "fuse.js": "6.6.2",
    "graphql": "16.8.1",
    "hls.js": "^1.6.16",
    "lodash": "4.18.1",
    "moment": "2.29.4",
    "phoenix": "1.7.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-player": "2.12.0",
